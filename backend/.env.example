# Copy to backend/.env for local development. NEVER commit a real .env.
# In production these are provided as GitHub Secrets / Fly.io secrets.

# LLM provider. Use "auto", "openai", or "anthropic".
# In auto mode, OPENAI_API_KEY is preferred when present; otherwise Anthropic is
# used if ANTHROPIC_API_KEY is present. If neither is set, deterministic review
# still produces F1/F2/F3 results.
LLM_PROVIDER=auto
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Email used for the Crossref "polite pool" (higher, more reliable rate limits).
CROSSREF_POLITE_EMAIL=

# Optional KCI (Korea Citation Index) Open API key for Korean-paper fallback.
# When unset, the KCI verification step is skipped.
KCI_API_KEY=

# F3 verification tuning.
F3_CONCURRENCY=8        # references verified in parallel (fan-out)
OPENALEX_ENABLED=true   # use OpenAlex as a secondary verifier (Korean titles)

# Optional LangSmith tracing (development only).
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false

# Redis URL. A non-localhost URL enables the durable Redis job store (jobs are
# shared across serverless/multi-instance deployments); localhost = in-memory.
REDIS_URL=redis://localhost:6379/0

# Comma-separated list of allowed CORS origins for the frontend.
CORS_ORIGINS=http://localhost:3000

# Model routing (override defaults if desired).
MODEL_TRIVIAL=claude-haiku-4-5
MODEL_SEMANTIC=claude-sonnet-4-6
MODEL_FINAL=claude-opus-4-7
OPENAI_MODEL_TRIVIAL=gpt-4.1-mini
OPENAI_MODEL_SEMANTIC=gpt-4.1
OPENAI_MODEL_FINAL=gpt-4.1
